#!/bin/sh /etc/rc.common

USE_PROCD=1
START=99
STOP=10

start_service() {
    procd_open_instance
    # 这里填写 geph5-client 的实际启动参数
    # 例如：procd_set_param command /usr/bin/geph5-client --config /etc/geph5.yaml
    procd_set_param command /usr/bin/geph5-client
    
    procd_set_param respawn
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}
